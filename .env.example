SECRET_KEY=change_me_now
CORS_ORIGINS=http://localhost:8081
DATABASE_URL=postgresql+psycopg2://signportal:signportal_pass@db:5432/signportal
UPLOAD_DIR=/app/storage/uploads
SIGNED_DIR=/app/storage/signed
MAX_FILE_MB=25
SIGNSERVER_BASE_URL=https://signserver.lab.local:8443/signserver
SIGNSERVER_WORKER_ID=PDFSigner
SIGNSERVER_AUTH_TYPE=none
SIGNSERVER_USERNAME=
SIGNSERVER_PASSWORD=
SIGNSERVER_TLS_VERIFY=false
SIGNSERVER_CLIENT_CERT=
SIGNSERVER_CLIENT_KEY=
SIGNSERVER_TIMEOUT=60
SIGNSERVER_MODE=process_servlet
TSA_ENABLED=true
TSA_URL=https://signserver.lab.local:8443/signserver/tsa
TSA_WORKER_NAME=TimeStampSigner
LDAP_ENABLED=false
LDAP_URL=ldaps://ad.lab.local:636
LDAP_BIND_DN=CN=svc_signportal,OU=Service Accounts,DC=lab,DC=local
LDAP_BIND_PASSWORD=ChangeMe
LDAP_BASE_DN=DC=lab,DC=local
LDAP_USER_FILTER=(sAMAccountName={username})
LDAP_ADMIN_GROUP=CN=SignPortal-Admins,OU=Groups,DC=lab,DC=local
LDAP_SIGNER_GROUP=CN=SignPortal-Signers,OU=Groups,DC=lab,DC=local
LDAP_VIEWER_GROUP=CN=SignPortal-Viewers,OU=Groups,DC=lab,DC=local
LDAP_TLS_VERIFY=false

SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Keyfactor SignPortal
APP_PUBLIC_URL=http://localhost:8081
